{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrithunjoyB/cpp-event-driven-backtester/manifests/schema/reproducibility-manifest-v1.schema.json",
  "title": "Quant Research Reproducibility Manifest",
  "type": "object",
  "required": [
    "manifest_schema_version", "manifest_id", "experiment_id", "package_type",
    "source_commit", "inputs", "configuration", "execution", "randomness",
    "methodology", "commands", "outputs", "validators", "lineage",
    "reproducibility_level", "known_volatile_fields"
  ],
  "properties": {
    "manifest_schema_version": {"const": 1},
    "manifest_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "experiment_id": {"type": "string", "minLength": 1},
    "package_type": {"type": "string", "minLength": 1},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "inputs": {"type": "array", "minItems": 1},
    "commands": {"type": "array", "minItems": 1},
    "reproducibility_level": {"enum": ["exact_byte", "canonical_semantic", "methodological"]}
  },
  "additionalProperties": false
}
